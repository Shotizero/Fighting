<Application x:Class="Fighting.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Fighting"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <Style x:Key="ButtomSave" TargetType="Button">
            <Setter Property="Template">
            <Setter.Value>
            <ControlTemplate TargetType="Button">
                <Border Background="Transparent"
                                BorderBrush="Green"
                                BorderThickness="3"
                                CornerRadius="100">
                </Border>
            </ControlTemplate>
                 </Setter.Value>
             </Setter>
        </Style>

        <Style x:Key="ButtomAtack" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent"
                        BorderBrush="Red"
                        BorderThickness="3"
                        CornerRadius="100">
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Application.Resources>
</Application>
