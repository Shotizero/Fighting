<Window x:Class="Fighting.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Fighting"
        mc:Ignorable="d"
        Title="DockPanel" Height="443" Width="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        
        <MediaElement x:Name="myVideo"
                      Source="C:\Users\akkur\source\repos\Fighting\Materials\Фон.mp4" 
                      Stretch="fill"
                      LoadedBehavior="Manual"
                      MediaEnded="myVideo_MediaEnded"
                      Grid.RowSpan="6"
                      Grid.ColumnSpan="6"
         />

        <Image Source="C:\Users\akkur\source\repos\Fighting\Materials\Scorpion.png"
             HorizontalAlignment="Right"
             VerticalAlignment="Bottom"
             Grid.RowSpan="4"
             Grid.Row="1"
                   />
        <Grid Grid.ColumnSpan="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="5*"/>
                <RowDefinition/>
                <RowDefinition Height="5*"/>
            </Grid.RowDefinitions>

            <ProgressBar x:Name="PlayerHP"
                         Grid.Column="1"
                         Grid.Row="1"
                         Foreground="#FF660000"
                         Background="Black"
                         BorderBrush="Transparent"
                         Minimum="0" Maximum="100" Value="100"/>

            <ProgressBar x:Name="EnemyHP"
                         Grid.Column="4"
                         Grid.Row="1"
                         Foreground="#FF660000"
                         Background="Black"
                         BorderBrush="Transparent"
                         Minimum="0" Maximum="100" Value="100"/>

        </Grid>

        <Grid Grid.Column="0" Grid.RowSpan="3" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="3*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Button
                Click="seveButton"
                Style="{StaticResource Button}"
                Grid.RowSpan="2"
                Grid.Column="2"/>
                
            </Grid>
            
                <Button Style="{StaticResource Button}"
                Click="seveButton"
                Grid.Column="1"
                Grid.RowSpan="1"
                Grid.Row="1"/>

                <Button Style="{StaticResource Button}"
                Click="seveButton"
                Grid.Column="1"
                Grid.Row="2"/>
            
        </Grid>

        <Image Source="C:\Users\akkur\source\repos\Fighting\Materials\Subzero.png"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Bottom"
                   Grid.Row="1"
                   Grid.Column="4"
                   Grid.RowSpan="5"
                   />
        <Grid Grid.Column="3" Grid.RowSpan="3" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="3*"/> 
            </Grid.RowDefinitions>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>                    
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Button 
                Click="definitions"
                Tag="Head"
                Grid.RowSpan="2"
                Grid.Column="1"
                Style="{StaticResource Button}"
                />
            </Grid>

            <Button
                Style="{StaticResource Button}"
                Click="definitions"
                Tag="Body"
                Grid.Column="1"
                Grid.RowSpan="1"
                Grid.Row="1"/>

            <Button Style="{StaticResource Button}"
                Click="definitions"
                Tag="Legs"
                Grid.Column="1"
                Grid.Row="2"/>
        </Grid>

            <Button     Width="20" Height="20"
                    Content="Exit" IsCancel="True"
                    Click="exitButton"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    />        

            <TextBox x:Name="Text"  
                     Background="Transparent"
                     Grid.RowSpan="1"
                     Grid.ColumnSpan="1"
                     Grid.Row="3"
                     Grid.Column="1"
                     BorderBrush="Transparent"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     Foreground="White"
                     FontSize="10"
                     Focusable="False"
                     IsHitTestVisible="False"
                     VerticalScrollBarVisibility="Hidden"
                     VerticalContentAlignment="Bottom"/>     
        
    </Grid>
</Window>
