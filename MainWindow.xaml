<Window x:Class="Fighting.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Fighting"
        mc:Ignorable="d"
        Title="DockPanel" Height="443" Width="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <MediaElement x:Name="myVideo"
                      Source="C:\Users\akkur\source\repos\Fighting\Materials\Фон.mp4" 
                      Stretch="fill"
                      LoadedBehavior="Manual"
                      MediaEnded="myVideo_MediaEnded"
                      Grid.RowSpan="6"
                      Grid.ColumnSpan="6"
         />

        <Image Source="C:\Users\akkur\source\repos\Fighting\Materials\Scorpion.png"
             HorizontalAlignment="Right"
             VerticalAlignment="Bottom"
             Grid.RowSpan="4"
             Grid.Row="1"
                   />

        <Button Width="50"
                Height="50"
                Click="seveHeadButton"
                Style="{StaticResource ButtonSave}"
                Grid.Row="1"
        />
        <Button Style="{StaticResource ButtonSave}"
                Width="100"
                Height="100"
                Click="seveBodyButton"
                Grid.Column="0"
                Grid.RowSpan="2"
                Grid.Row="1"/>

        <Button Style="{StaticResource ButtonSave}"
                Width="100"
                Height="100"
                Click="seveLedsButton"
                Grid.Column="0"
                Grid.Row="3"/>

        <Image Source="C:\Users\akkur\source\repos\Fighting\Materials\Subzero.png"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Bottom"
                   Grid.Row="1"
                   Grid.Column="4"
                   Grid.RowSpan="5"
                   />
       
        <Button Width="50"
                Height="50"
                Click="atackHeadButton"
                Style="{StaticResource ButtonAtack}"
                Grid.Column="3"
                Grid.Row="1"
/>
        <Button Style="{StaticResource ButtonAtack}"
                Width="100"
                Height="100"
                Click="atackBodyButton"
                Grid.Column="3"
                Grid.RowSpan="2"
                Grid.Row="1"/>

        <Button Style="{StaticResource ButtonAtack}"
                Width="100"
                Height="100"
                Click="atackLedsButton"
                Grid.Column="3"
                Grid.Row="3"/>

        <Button     Width="20" Height="20"
                    Content="Exit" IsCancel="True"
                    Click="exitButton"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    />

        <ScrollViewer Grid.RowSpan="2"
                      Grid.ColumnSpan="2"
                      Grid.Row="1"
                      Grid.Column="1">
            <TextBox
                     Background="Transparent"
                     BorderBrush="Red"
                     IsReadOnly="True"
                     />
        </ScrollViewer>



    </Grid>

</Window>
